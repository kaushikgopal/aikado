{
  "model": "us.anthropic.claude-opus-4-6-v1",
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay $XDG_DATA_HOME/sound-notification-human"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay $XDG_DATA_HOME/sound-done-human"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/bash-permission.sh",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Write|Edit|Read|Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/file-edit-permission.sh",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/mcp-permission.sh",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Task|TaskOutput|TaskStop|TaskCreate|TaskUpdate|TaskList|TaskGet|WebFetch|WebSearch|AskUserQuestion|EnterPlanMode|ExitPlanMode|Skill|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/safe-operations-permission.sh",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "annual-reviews@instacart": false,
    "context7@claude-plugins-official": true,
    "document-skills@anthropic-agent-skills": false,
    "superpowers@claude-plugins-official": true
  },
  "outputStyle": "Explanatory",
  "spinnerTipsEnabled": false,
  "skipDangerousModePermissionPrompt": true,
  "permissions": {
    "allow": [
      "*",
      "Bash",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Task",
      "TodoWrite",
      "WebFetch",
      "WebSearch",
      "NotebookEdit",
      "NotebookRead",
      "AskUserQuestion",
      "Skill",
      "SlashCommand",
      "BashOutput",
      "KillShell",
      "mcp__playwright__*",
      "mcp__chrome-devtools__*",
      "mcp__glean_default__*"
    ],
    "deny": [],
    "ask": [
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(rm:*)",
      "Bash(isc:*)"
    ],
    "defaultMode": "acceptEdits"
  }
}
